<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giver – Gift Recommendation System</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
         :root {
            --cream: #F5F0E8;
            --warm-white: #FDFAF4;
            --dark-brown: #3D2E22;
            --mid-brown: #6B4F3A;
            --accent-red: #C0392B;
            --gold: #C9A84C;
            --text-body: #5A4A3A;
            --step-bg: #EDE5D8;
        }
        
        html {
            scroll-behavior: smooth;
        }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--warm-white);
            color: var(--text-body);
            overflow-x: hidden;
        }
        /* ─── NAVBAR ─── */
        
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 48px;
            background: var(--warm-white);
            border-bottom: 1px solid rgba(61, 46, 34, .08);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            color: var(--dark-brown);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .nav-logo svg {
            width: 22px;
            height: 22px;
        }
        
        .nav-links {
            display: flex;
            gap: 24px;
            align-items: center;
        }
        
        .nav-links a {
            text-decoration: none;
            color: var(--text-body);
            font-size: .88rem;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color .2s;
        }
        
        .nav-links a:hover {
            color: var(--dark-brown);
        }
        
        .btn-register {
            background: var(--dark-brown);
            color: #fff !important;
            padding: 8px 18px;
            border-radius: 4px;
            font-size: .85rem !important;
        }
        /* ─── HERO ─── */
        
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 560px;
            background: var(--cream);
            overflow: hidden;
        }
        
        .hero-left {
            padding: 72px 56px 64px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            animation: fadeUp .9s ease both;
        }
        
        .hero-badge {
            font-size: .72rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--mid-brown);
            border-bottom: 1.5px solid var(--mid-brown);
            display: inline-block;
            padding-bottom: 2px;
            margin-bottom: 28px;
        }
        
        .hero-left h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 3.5vw, 3rem);
            line-height: 1.2;
            color: var(--dark-brown);
            margin-bottom: 20px;
        }
        
        .hero-left h1 em {
            font-style: italic;
            color: var(--mid-brown);
        }
        
        .hero-left p {
            font-size: .92rem;
            line-height: 1.7;
            color: var(--text-body);
            max-width: 380px;
            margin-bottom: 36px;
        }
        
        .hero-ctas {
            display: flex;
            gap: 14px;
            align-items: center;
            margin-bottom: 48px;
        }
        
        .btn-primary {
            background: var(--dark-brown);
            color: #fff;
            padding: 12px 24px;
            border: none;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            font-size: .88rem;
            letter-spacing: .04em;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, transform .15s;
        }
        
        .btn-primary:hover {
            background: var(--mid-brown);
            transform: translateY(-1px);
        }
        
        .btn-ghost {
            background: transparent;
            color: var(--text-body);
            border: none;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            font-size: .88rem;
            text-decoration: underline;
            text-underline-offset: 3px;
        }
        
        .hero-stats {
            display: flex;
            gap: 36px;
        }
        
        .stat-item {
            display: flex;
            flex-direction: column;
        }
        
        .stat-number {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            color: var(--dark-brown);
            font-weight: 600;
        }
        
        .stat-label {
            font-size: .72rem;
            color: var(--mid-brown);
            margin-top: 2px;
        }
        /* hero right – photo collage */
        
        .hero-right {
            position: relative;
            overflow: hidden;
        }
        
        .collage {
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: 1fr 1fr;
            height: 100%;
            gap: 3px;
        }
        
        .collage-cell {
            overflow: hidden;
            background: #D4C5B0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .collage-cell img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }
        
        .collage-cell:hover img {
            transform: scale(1.05);
        }
        /* placeholder gift SVG shown if images don't load */
        
        .collage-cell svg {
            width: 60px;
            height: 60px;
            opacity: .3;
        }
        /* ─── HOW IT WORKS ─── */
        
        .how-section {
            background: var(--dark-brown);
            padding: 80px 48px;
            animation: fadeUp .9s ease both;
        }
        
        .section-eyebrow {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 32px;
        }
        
        .section-eyebrow span {
            font-size: .75rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, .5);
        }
        
        .eyebrow-line {
            width: 48px;
            height: 1px;
            background: rgba(255, 255, 255, .3);
        }
        
        .how-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.8rem, 3vw, 2.6rem);
            color: var(--cream);
            margin-bottom: 56px;
        }
        
        .how-section h2 em {
            font-style: italic;
            color: var(--gold);
        }
        
        .steps-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }
        
        .step-card {
            background: var(--step-bg);
            border-radius: 4px;
            padding: 32px 24px;
            position: relative;
            transition: transform .25s, box-shadow .25s;
        }
        
        .step-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, .2);
        }
        
        .step-number {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            color: rgba(61, 46, 34, .15);
            font-weight: 600;
            position: absolute;
            top: 16px;
            right: 20px;
            line-height: 1;
        }
        
        .step-icon {
            width: 44px;
            height: 44px;
            margin-bottom: 20px;
            color: var(--mid-brown);
        }
        
        .step-card h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            color: var(--dark-brown);
            margin-bottom: 10px;
        }
        
        .step-card p {
            font-size: .82rem;
            line-height: 1.65;
            color: var(--text-body);
        }
        /* ─── CTA ─── */
        
        .cta-section {
            padding: 100px 48px;
            text-align: center;
            background: var(--warm-white);
            position: relative;
        }
        
        .sparkle-group {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .sparkle {
            color: var(--gold);
            font-size: 1.1rem;
        }
        
        .cta-eyebrow {
            font-size: .75rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: var(--mid-brown);
            margin-bottom: 20px;
        }
        
        .cta-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 3.5vw, 2.8rem);
            color: var(--dark-brown);
            margin-bottom: 14px;
        }
        
        .cta-section h2 em {
            font-style: italic;
            color: var(--mid-brown);
        }
        
        .cta-section p {
            font-size: .92rem;
            color: var(--text-body);
            margin-bottom: 40px;
            max-width: 420px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.6;
        }
        
        .cta-buttons {
            display: flex;
            justify-content: center;
            gap: 16px;
        }
        
        .btn-outline {
            border: 1.5px solid var(--dark-brown);
            color: var(--dark-brown);
            background: transparent;
            padding: 12px 24px;
            font-family: 'DM Sans', sans-serif;
            font-size: .88rem;
            cursor: pointer;
            transition: background .2s, color .2s;
        }
        
        .btn-outline:hover {
            background: var(--dark-brown);
            color: #fff;
        }
        /* ─── FOOTER ─── */
        
        footer {
            background: var(--cream);
            border-top: 1px solid rgba(61, 46, 34, .1);
            padding: 20px 48px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: .75rem;
            color: var(--mid-brown);
        }
        
        .footer-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            color: var(--dark-brown);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        /* ─── ANIMATIONS ─── */
        
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav>
        <div class="nav-logo">
            <!-- Gift box icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <rect x="3" y="8" width="18" height="13" rx="1"/>
      <path d="M12 8v13M3 12h18"/>
