      </svg>
                <h3>Add a Recipient</h3>
                <p>Save recipient details such as their name, relationship, and interests so the system can make accurate matches.</p>
            </div>

            <!-- Step 2 -->
            <div class="step-card">
                <span class="step-number">02</span>
                <!-- Gear / analysis icon -->
                <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
        <circle cx="12" cy="12" r="7" stroke-dasharray="3 3"/>
      </svg>
                <h3>Analysis</h3>
                <p>Our engine processes the data and intelligently matches it against a catalog of 500+ curated gifts.</p>
            </div>

            <!-- Step 3 -->
            <div class="step-card">
                <span class="step-number">03</span>
                <!-- Gift box icon -->
                <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <rect x="3" y="8" width="18" height="13" rx="1"/>
        <path d="M12 8v13M3 12h18"/>
        <path d="M9 8C9 6 10 4 12 4s3 2-3 4"/>
        <path d="M15 8C15 6 14 4 12 4S9 6 15 8"/>
      </svg>
                <h3>Choose a Gift</h3>
                <p>Compare and pick from the suggestions, complete with details, pricing, and reviews.</p>
            </div>

            <!-- Step 4 -->
            <div class="step-card">
                <span class="step-number">04</span>
                <!-- Shopping bag icon -->
                <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
